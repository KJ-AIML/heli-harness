{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/hooks/heli-session-start.mjs\"",
            "timeout": 5,
            "statusMessage": "Loading Heli-Harness context..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${GROK_PLUGIN_ROOT}/hooks/heli-pre-tool-use.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking Heli-Harness safety policy..."
          }
        ]
      }
    ]
  }
}
