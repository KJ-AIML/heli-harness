{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HELI_GROK_HOOKS}/heli-session-start.mjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${HELI_GROK_HOOKS}/heli-pre-tool-use.mjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
