{
  "name": "heli-harness",
  "version": "0.4.3",
  "description": "Parent-workspace AI development harness for multi-repo, multi-agent engineering work.",
  "keywords": [
    "pi-package",
    "pi",
    "heli-harness",
    "coding-agent",
    "multi-agent"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KJ-AIML/heli-harness.git"
  },
  "files": [
    ".heli-harness/",
    "extensions/",
    "scripts/",
    "install.sh",
    "install.ps1",
    "update.sh",
    "update.ps1",
    "uninstall.sh",
    "uninstall.ps1",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "check": "node --check extensions/pi-extension.js && node scripts/smoke-extension-load.mjs && node scripts/validate-release.mjs",
    "smoke": "node scripts/smoke-extension-load.mjs",
    "validate:release": "node scripts/validate-release.mjs"
  },
  "pi": {
    "extensions": [
      "./extensions/pi-extension.js"
    ],
    "skills": [
      "./.heli-harness/skills"
    ]
  }
}
